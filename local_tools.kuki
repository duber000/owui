# local_tools.kuki — built-in sandboxed tools (mini-claude-code mode)
#
# File ops:   stdlib/sandbox (os.Root kernel-level path confinement)
# Net filter: stdlib/netguard (IP allow/block with DNS rebinding protection)
# Shell cmds: stdlib/shell with an explicit command allowlist
#
# Tools exposed to the LLM:
#   read_file, write_file, list_dir, search_files, grep_files, run_command

petiole main

import "os"
import "path/filepath"
import "stdlib/json" as jsonpkg
import "stdlib/llm"
import "stdlib/llm/chat"
import "stdlib/netguard"
import "stdlib/sandbox"
import "stdlib/shell"
import "stdlib/slice"
import "stdlib/string" as strpkg

func defaultCmdAllowList() list of string
    return list of string{
        "bd",
        "cat",
        "cp",
        "date",
        "diff",
        "echo",
        "find",
        "git",
        "grep",
        "head",
        "ls",
        "mkdir",
        "mv",
        "pwd",
        "rm",
        "sort",
        "tail",
        "touch",
        "uniq",
        "wc",
        "which",
    }

# LocalTool is the closed set of built-in tool names exposed to the LLM.
# The raw values are the wire-format names sent to and received from the LLM.
# ParseLocalTool is used at the dispatch boundary to reject unknown names.
enum LocalTool: string
    ReadFile = "read_file"
    WriteFile = "write_file"
    ListDir = "list_dir"
    SearchFiles = "search_files"
    GrepFiles = "grep_files"
    RunCommand = "run_command"

func allLocalTools() list of LocalTool
    return list of LocalTool{
        LocalTool.ReadFile,
        LocalTool.WriteFile,
        LocalTool.ListDir,
        LocalTool.SearchFiles,
        LocalTool.GrepFiles,
        LocalTool.RunCommand,
    }

# LocalTools holds the sandbox root and optional network guard.
type LocalTools
    Box: sandbox.Root
    Guard: netguard.Guard
    HasGuard: bool
    AllowedCmds: StringSet

# buildLocalTools initialises sandbox + optional netguard from Config.
# Defaults sandbox root to the process CWD when SandboxDir is unset.
func buildLocalTools(cfg: Config) (LocalTools, error)
    lt := LocalTools{AllowedCmds: make(StringSet)}

    sandboxDir := cfg.SandboxDir
    if sandboxDir equals ""
        cwd := os.Getwd() onerr explain "sandbox cwd"
        sandboxDir = cwd

    box := sandbox.New(sandboxDir) onerr explain "sandbox"
    lt.Box = box

    if len(cfg.IPAllowList) > 0
        g := netguard.NewAllow(cfg.IPAllowList) onerr explain "netguard allow"
        lt.Guard = g
        lt.HasGuard = true
    else if len(cfg.IPBlockList) > 0
        g := netguard.NewBlock(cfg.IPBlockList) onerr explain "netguard block"
        lt.Guard = g
        lt.HasGuard = true

    allowed := cfg.CmdAllowList
    if len(allowed) equals 0
        allowed = defaultCmdAllowList()
    for cmd in allowed
        lt.AllowedCmds[cmd] = true

    return lt, empty

func closeLocalTools(lt: LocalTools) error
    return sandbox.Close(lt.Box)

# registerLocalTools attaches built-in tools to an existing Bridge.
func registerLocalTools(b: reference Bridge, cfg: Config) error
    lt := buildLocalTools(cfg)
    b.LocalTools = lt
    for _, t in allLocalTools()
        b.LocalToolNames[t.String()] = true
    return empty

# ---- Tool registry ----

# toolDef wraps an chat.Tool literal so each registration reads as one line.
func toolDef(name: string, description: string, schema: llm.JSONObject) chat.Tool
    return chat.Tool{
        Type: "function",
        Function: chat.ToolFunction{
            Name: name,
            Description: description,
            Parameters: schema,
        },
    }

func localToolDefs() list of chat.Tool
    readSchema := llm.Schema({
        llm.Prop("path", "string", "File path relative to sandbox root"),
    })
        |> llm.Required({"path"})

    writeSchema := llm.Schema({
        llm.Prop("path", "string", "File path relative to sandbox root"),
        llm.Prop("content", "string", "Content to write"),
    })
        |> llm.Required({"path", "content"})

    listSchema := llm.Schema({
        llm.Prop("path", "string", "Directory path relative to sandbox root (default: .)"),
    })

    searchSchema := llm.Schema({
        llm.Prop("pattern", "string", "File name glob pattern (e.g. *.go, main.*)"),
    })
        |> llm.Required({"pattern"})

    grepSchema := llm.Schema({
        llm.Prop("pattern", "string", "Regex or literal text to search for"),
        llm.Prop("path", "string", "Path within sandbox to search (default: .)"),
    })
        |> llm.Required({"pattern"})

    # run_command has an array-typed `args` property — llm.Schema only
    # expresses scalar types today, so build this one by hand.
    runProps := llm.JSONObject{
        "cmd": llm.JSONObject{
            "type": "string",
            "description": "Command name — allowed: {strpkg.Join(defaultCmdAllowList(), " ")}",
        },
        "args": llm.JSONObject{
            "type": "array",
            "items": llm.JSONObject{"type": "string"},
            "description": "Command arguments",
        },
    }
    runSchema := llm.JSONObject{
        "type": "object",
        "properties": runProps,
        "required": list of string{"cmd"},
    }

    return list of chat.Tool{
        toolDef(
            LocalTool.ReadFile.String(),
            "Read the contents of a file within the sandbox",
            readSchema,
        ),
        toolDef(
            LocalTool.WriteFile.String(),
            "Write or overwrite a file within the sandbox",
            writeSchema,
        ),
        toolDef(
            LocalTool.ListDir.String(),
            "List files and directories within a sandbox directory",
            listSchema,
        ),
        toolDef(
            LocalTool.SearchFiles.String(),
            "Search for files matching a name pattern within the sandbox",
            searchSchema,
        ),
        toolDef(
            LocalTool.GrepFiles.String(),
            "Search file contents for a pattern within the sandbox",
            grepSchema,
        ),
        toolDef(
            LocalTool.RunCommand.String(),
            "Run an allowlisted shell command in the sandbox directory",
            runSchema,
        ),
    }

# ---- Tool calls (variant enum) ----

# LocalToolCall is the parsed, typed form of an LLM tool invocation. The
# JSON-arg decode happens once in parseLocalToolCall; downstream handlers
# receive validated, typed payloads. Adding a new tool variant here makes
# the dispatch switch a compile error until every site handles it.
enum LocalToolCall
    ReadFile
        path: string
    WriteFile
        path: string
        content: string
    ListDir
        path: string
    SearchFiles
        pattern: string
    GrepFiles
        pattern: string
        path: string
    RunCommand
        cmd: string
        args: list of string

# JSON-decode targets — kept private; they exist only to carry the wire
# format's tags into the LocalToolCall constructor.
type readFileArgs
    Path: string as "path"

type writeFileArgs
    Path: string as "path"
    Content: string as "content"

type listDirArgs
    Path: string as "path"

type searchFilesArgs
    Pattern: string as "pattern"

type grepFilesArgs
    Pattern: string as "pattern"
    Path: string as "path"

type runCommandArgs
    Cmd: string as "cmd"
    Args: list of string as "args"

# parseLocalToolCall resolves the tool name and decodes its argument JSON
# in one step. Missing-required-field validation lives here so handlers
# see only well-formed inputs.
func parseLocalToolCall(name: string, argsJSON: string) (LocalToolCall, error)
    tool := ParseLocalTool(name) onerr
        return ReadFile{}, error "unknown local tool: {name}"

    switch tool
        when LocalTool.ReadFile
            a := jsonpkg.ParseString of readFileArgs from argsJSON onerr return ReadFile{}, error "read_file: bad args: {error}"
            if a.Path equals ""
                return ReadFile{}, error "read_file: missing path"
            return ReadFile{path: a.Path}, empty
        when LocalTool.WriteFile
            a := jsonpkg.ParseString of writeFileArgs from argsJSON onerr return ReadFile{}, error "write_file: bad args: {error}"
            if a.Path equals ""
                return ReadFile{}, error "write_file: missing path"
            return WriteFile{path: a.Path, content: a.Content}, empty
        when LocalTool.ListDir
            # list_dir tolerates empty argsJSON — defaults to "."
            a := listDirArgs{}
            if argsJSON isnt "" and argsJSON isnt "{}"
                a = jsonpkg.ParseString of listDirArgs from argsJSON onerr return ReadFile{}, error "list_dir: bad args: {error}"
            path := a.Path
            if path equals ""
                path = "."
            return ListDir{path: path}, empty
        when LocalTool.SearchFiles
            a := jsonpkg.ParseString of searchFilesArgs from argsJSON onerr return ReadFile{}, error "search_files: bad args: {error}"
            if a.Pattern equals ""
                return ReadFile{}, error "search_files: missing pattern"
            return SearchFiles{pattern: a.Pattern}, empty
        when LocalTool.GrepFiles
            a := jsonpkg.ParseString of grepFilesArgs from argsJSON onerr return ReadFile{}, error "grep_files: bad args: {error}"
            if a.Pattern equals ""
                return ReadFile{}, error "grep_files: missing pattern"
            searchPath := a.Path
            if searchPath equals ""
                searchPath = "."
            return GrepFiles{pattern: a.Pattern, path: searchPath}, empty
        when LocalTool.RunCommand
            a := jsonpkg.ParseString of runCommandArgs from argsJSON onerr return ReadFile{}, error "run_command: bad args: {error}"
            if a.Cmd equals ""
                return ReadFile{}, error "run_command: missing cmd"
            return RunCommand{cmd: a.Cmd, args: a.Args}, empty
    return ReadFile{}, error "unreachable local tool: {name}"

# ---- Tool dispatch ----

func dispatchLocalTool(lt: LocalTools, name: string, argsJSON: string) (string, error)
    call, err := parseLocalToolCall(name, argsJSON)
    if err isnt empty
        return "", err
    switch call
        when ReadFile
            return localReadFile(lt, call.path)
        when WriteFile
            return localWriteFile(lt, call.path, call.content)
        when ListDir
            return localListDir(lt, call.path)
        when SearchFiles
            return localSearchFiles(lt, call.pattern)
        when GrepFiles
            return localGrepFiles(lt, call.pattern, call.path)
        when RunCommand
            return localRunCommand(lt, call.cmd, call.args)

# ---- Implementations ----

func localReadFile(lt: LocalTools, path: string) (string, error)
    content := sandbox.ReadString(lt.Box, path) onerr return "", error "read_file: {error}"
    return content, empty

func localWriteFile(lt: LocalTools, path: string, content: string) (string, error)
    sandbox.WriteString(lt.Box, content, path) onerr return "", error "write_file: {error}"
    return "wrote {len(content)} bytes to {path}", empty

func localListDir(lt: LocalTools, path: string) (string, error)
    names := sandbox.List(lt.Box, path) onerr return "", error "list_dir: {error}"
    if len(names) equals 0
        return "(empty)", empty
    return strpkg.Join(names, "\n"), empty

func localSearchFiles(lt: LocalTools, pattern: string) (string, error)
    sandboxPath := lt.Box.Path
    out := shell.New("find", sandboxPath)
        |> .Flag("-name", pattern)
        |> .Execute()
    return formatRelativeMatches(out.Stdout as string, sandboxPath), empty

func localGrepFiles(lt: LocalTools, pattern: string, searchPath: string) (string, error)
    sandboxPath := lt.Box.Path
    fullPath := filepath.Join(sandboxPath, searchPath)
    rel := filepath.Rel(sandboxPath, fullPath) onerr return "", error "grep_files: invalid path"
    if strpkg.HasPrefix(rel, "..")
        return "", error "grep_files: path escapes sandbox"
    out := shell.New("grep", "-r", "-n", pattern, fullPath) |> .Execute()
    return formatRelativeMatches(out.Stdout as string, sandboxPath), empty

# formatRelativeMatches trims the sandbox prefix from each non-empty line of `stdout`
# so paths shown to the LLM are sandbox-relative, not absolute.
func formatRelativeMatches(stdout: string, sandboxPath: string) string
    raw := strpkg.TrimSpace(stdout)
    if raw equals ""
        return "(no matches)"
    prefix := sandboxPath + "/"
    matches := strpkg.Split(raw, "\n")
        |> slice.Filter(l => l isnt "")
        |> slice.Map(l => strpkg.TrimPrefix(l, prefix))
    return strpkg.Join(matches, "\n")

func localRunCommand(lt: LocalTools, cmd: string, args: list of string) (string, error)
    if not lt.AllowedCmds[cmd]
        return "", error "run_command: '{cmd}' is not in the allowed command list"
    sandboxPath := lt.Box.Path
    out := shell.New(cmd, many args) |> .Dir(sandboxPath) |> .Execute()
    stdout := strpkg.TrimSpace(out.Stdout as string)
    stderr := strpkg.TrimSpace(out.Stderr as string)
    combined := stdout
    if stderr isnt ""
        if combined isnt ""
            combined = "{combined}\n[stderr]\n{stderr}"
        else
            combined = "[stderr]\n{stderr}"
    if combined equals ""
        combined = "(no output)"
    if not out.Success()
        return combined, error "exited {out.ExitCode}"
    return combined, empty
