# local_tools.kuki — built-in sandboxed tools (mini-claude-code mode)
#
# File ops:   stdlib/sandbox (os.Root kernel-level path confinement)
# Net filter: stdlib/netguard (IP allow/block with DNS rebinding protection)
# Shell cmds: stdlib/shell with an explicit command allowlist
#
# Tools exposed to the LLM:
#   read_file, write_file, list_dir, search_files, grep_files, run_command

petiole main

import "os"
import "path/filepath"
import "stdlib/json" as jsonpkg
import "stdlib/llm"
import "stdlib/llm/chat"
import "stdlib/netguard"
import "stdlib/sandbox"
import "stdlib/shell"
import "stdlib/slice"
import "stdlib/string" as strpkg

func defaultCmdAllowList() list of string
    return list of string{
        "bd", "cat", "cp", "date", "diff", "echo", "find", "git",
        "grep", "head", "ls", "mkdir", "mv", "pwd", "rm", "sort",
        "tail", "touch", "uniq", "wc", "which",
    }

# LocalTools holds the sandbox root and optional network guard.
type LocalTools
    Box         sandbox.Root
    Guard       netguard.Guard
    HasGuard    bool
    AllowedCmds map of string to bool

# buildLocalTools initialises sandbox + optional netguard from Config.
# Defaults sandbox root to the process CWD when SandboxDir is unset.
func buildLocalTools(cfg Config) (LocalTools, error)
    lt := LocalTools{AllowedCmds: make(map of string to bool)}

    sandboxDir := cfg.SandboxDir
    if sandboxDir equals ""
        cwd := os.Getwd() onerr explain "sandbox cwd"
        sandboxDir = cwd

    box := sandbox.New(sandboxDir) onerr explain "sandbox"
    lt.Box = box

    if len(cfg.IPAllowList) > 0
        g := netguard.NewAllow(cfg.IPAllowList) onerr explain "netguard allow"
        lt.Guard = g
        lt.HasGuard = true
    else if len(cfg.IPBlockList) > 0
        g := netguard.NewBlock(cfg.IPBlockList) onerr explain "netguard block"
        lt.Guard = g
        lt.HasGuard = true

    allowed := cfg.CmdAllowList
    if len(allowed) equals 0
        allowed = defaultCmdAllowList()
    for cmd in allowed
        lt.AllowedCmds[cmd] = true

    return lt, empty

func closeLocalTools(lt LocalTools) error
    return sandbox.Close(lt.Box)

# registerLocalTools attaches built-in tools to an existing Bridge.
func registerLocalTools(b reference Bridge, cfg Config) error
    lt := buildLocalTools(cfg) onerr return
    b.LocalTools = lt
    for _, name in list of string{"read_file", "write_file", "list_dir", "search_files", "grep_files", "run_command"}
        b.LocalToolNames[name] = true
    return empty

# ---- Tool registry ----

# toolDef wraps an chat.Tool literal so each registration reads as one line.
func toolDef(name string, description string, schema map of string to any) chat.Tool
    return chat.Tool{
        Type: "function",
        Function: chat.ToolFunction{
            Name: name,
            Description: description,
            Parameters: schema,
        },
    }

func localToolDefs() list of chat.Tool
    readSchema := llm.Schema(list of llm.SchemaProperty{
        llm.Prop("path", "string", "File path relative to sandbox root"),
    }) |> llm.Required(list of string{"path"})

    writeSchema := llm.Schema(list of llm.SchemaProperty{
        llm.Prop("path", "string", "File path relative to sandbox root"),
        llm.Prop("content", "string", "Content to write"),
    }) |> llm.Required(list of string{"path", "content"})

    listSchema := llm.Schema(list of llm.SchemaProperty{
        llm.Prop("path", "string", "Directory path relative to sandbox root (default: .)"),
    })

    searchSchema := llm.Schema(list of llm.SchemaProperty{
        llm.Prop("pattern", "string", "File name glob pattern (e.g. *.go, main.*)"),
    }) |> llm.Required(list of string{"pattern"})

    grepSchema := llm.Schema(list of llm.SchemaProperty{
        llm.Prop("pattern", "string", "Regex or literal text to search for"),
        llm.Prop("path", "string", "Path within sandbox to search (default: .)"),
    }) |> llm.Required(list of string{"pattern"})

    # run_command has an array-typed `args` property — llm.Schema only
    # expresses scalar types today, so build this one by hand.
    runProps := map of string to any{
        "cmd": map of string to any{
            "type": "string",
            "description": "Command name — allowed: bd cat cp date diff echo find git grep head ls mkdir mv pwd rm sort tail touch uniq wc which",
        },
        "args": map of string to any{
            "type": "array",
            "items": map of string to any{"type": "string"},
            "description": "Command arguments",
        },
    }
    runSchema := map of string to any{
        "type": "object",
        "properties": runProps,
        "required": list of string{"cmd"},
    }

    return list of chat.Tool{
        toolDef("read_file", "Read the contents of a file within the sandbox", readSchema),
        toolDef("write_file", "Write or overwrite a file within the sandbox", writeSchema),
        toolDef("list_dir", "List files and directories within a sandbox directory", listSchema),
        toolDef("search_files", "Search for files matching a name pattern within the sandbox", searchSchema),
        toolDef("grep_files", "Search file contents for a pattern within the sandbox", grepSchema),
        toolDef("run_command", "Run an allowlisted shell command in the sandbox directory", runSchema),
    }

# ---- Tool dispatch ----

func dispatchLocalTool(lt LocalTools, name string, argsJSON string) (string, error)
    switch name
        when "read_file"
            return localReadFile(lt, argsJSON)
        when "write_file"
            return localWriteFile(lt, argsJSON)
        when "list_dir"
            return localListDir(lt, argsJSON)
        when "search_files"
            return localSearchFiles(lt, argsJSON)
        when "grep_files"
            return localGrepFiles(lt, argsJSON)
        when "run_command"
            return localRunCommand(lt, argsJSON)
        otherwise
            return "", error "unknown local tool: {name}"

# ---- Arg structs ----

type readFileArgs
    Path string as "path"

type writeFileArgs
    Path string as "path"
    Content string as "content"

type listDirArgs
    Path string as "path"

type searchFilesArgs
    Pattern string as "pattern"

type grepFilesArgs
    Pattern string as "pattern"
    Path string as "path"

type runCommandArgs
    Cmd string as "cmd"
    Args list of string as "args"

# ---- Implementations ----

func localReadFile(lt LocalTools, argsJSON string) (string, error)
    a := readFileArgs{}
    jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "read_file: bad args: {error}"
    if a.Path equals ""
        return "", error "read_file: missing path"
    content := sandbox.ReadString(lt.Box, a.Path) onerr return "", error "read_file: {error}"
    return content, empty

func localWriteFile(lt LocalTools, argsJSON string) (string, error)
    a := writeFileArgs{}
    jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "write_file: bad args: {error}"
    if a.Path equals ""
        return "", error "write_file: missing path"
    sandbox.WriteString(lt.Box, a.Content, a.Path) onerr return "", error "write_file: {error}"
    return "wrote {len(a.Content)} bytes to {a.Path}", empty

func localListDir(lt LocalTools, argsJSON string) (string, error)
    a := listDirArgs{}
    if argsJSON isnt "" and argsJSON isnt "{}"
        jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "list_dir: bad args: {error}"
    path := a.Path
    if path equals ""
        path = "."
    names := sandbox.List(lt.Box, path) onerr return "", error "list_dir: {error}"
    if len(names) equals 0
        return "(empty)", empty
    return strpkg.Join(names, "\n"), empty

func localSearchFiles(lt LocalTools, argsJSON string) (string, error)
    a := searchFilesArgs{}
    jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "search_files: bad args: {error}"
    if a.Pattern equals ""
        return "", error "search_files: missing pattern"
    sandboxPath := lt.Box.Path
    out := shell.New("find", sandboxPath)
        |> .Flag("-name", a.Pattern)
        |> .Execute()
    raw := strpkg.TrimSpace(out.Stdout as string)
    if raw equals ""
        return "(no matches)", empty
    prefix := sandboxPath + "/"
    lines := strpkg.Split(raw, "\n")
    results := lines
        |> slice.Filter((l string) bool => l isnt "")
        |> slice.Map((l string) string => strpkg.TrimPrefix(l, prefix))
    return strpkg.Join(results, "\n"), empty

func localGrepFiles(lt LocalTools, argsJSON string) (string, error)
    a := grepFilesArgs{}
    jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "grep_files: bad args: {error}"
    if a.Pattern equals ""
        return "", error "grep_files: missing pattern"
    sandboxPath := lt.Box.Path
    searchPath := a.Path
    if searchPath equals ""
        searchPath = "."
    fullPath := filepath.Join(sandboxPath, searchPath)
    rel := filepath.Rel(sandboxPath, fullPath) onerr return "", error "grep_files: invalid path"
    if strpkg.HasPrefix(rel, "..")
        return "", error "grep_files: path escapes sandbox"
    out := shell.New("grep", "-r", "-n", a.Pattern, fullPath) |> .Execute()
    raw := strpkg.TrimSpace(out.Stdout as string)
    if raw equals ""
        return "(no matches)", empty
    prefix := sandboxPath + "/"
    lines := strpkg.Split(raw, "\n")
    results := lines
        |> slice.Filter((l string) bool => l isnt "")
        |> slice.Map((l string) string => strpkg.TrimPrefix(l, prefix))
    return strpkg.Join(results, "\n"), empty

func localRunCommand(lt LocalTools, argsJSON string) (string, error)
    a := runCommandArgs{}
    jsonpkg.UnmarshalString(argsJSON, reference of a) onerr return "", error "run_command: bad args: {error}"
    if a.Cmd equals ""
        return "", error "run_command: missing cmd"
    _, ok := lt.AllowedCmds[a.Cmd]
    if not ok
        return "", error "run_command: '{a.Cmd}' is not in the allowed command list"
    sandboxPath := lt.Box.Path
    out := shell.New(a.Cmd, many a.Args) |> .Dir(sandboxPath) |> .Execute()
    stdout := strpkg.TrimSpace(out.Stdout as string)
    stderr := strpkg.TrimSpace(out.Stderr as string)
    combined := stdout
    if stderr isnt ""
        if combined isnt ""
            combined = "{combined}\n[stderr]\n{stderr}"
        else
            combined = "[stderr]\n{stderr}"
    if combined equals ""
        combined = "(no output)"
    if not out.Success()
        return combined, error "exited {out.ExitCode}"
    return combined, empty
