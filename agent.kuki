# Agent — runs the LLM <-> MCP tool call loop
# Uses stdlib/llm/chat for OpenAI-compatible chat completions (works with Open WebUI)
# Uses the MCP bridge for tool discovery and execution

petiole main

import "context"
import "stdlib/json" as jsonpkg
import "stdlib/llm"
import "stdlib/llm/chat"
import "stdlib/string" as strpkg

const defaultSystemPrompt string = "You are a helpful assistant with access to a sandboxed Linux environment via tool calls. You can execute commands, read/write files, search, and manage the filesystem. Use these tools to help the user accomplish their goals. Be concise in your explanations but thorough in your tool usage."

type Agent
    Bridge nullable reference Bridge
    Config Config
    SystemPrompt string
    MaxRounds int
    OnText func(string)
    OnToolCall func(string, string)
    OnToolResult func(string, string)

type RunResult
    Content string
    Messages list of chat.Message
    Rounds int

func runAgent(ctx: context.Context, a: reference Agent, userPrompt: string, history: list of chat.Message) (reference RunResult, error)
    maxRounds := a.MaxRounds
    if maxRounds equals 0
        # Safety bound on tool-loop iterations — prevents runaway models that keep
        # calling tools without producing a final answer. 15 is generous for typical
        # multi-step tasks and small enough to surface obvious loops quickly.
        maxRounds = 15

    messages := initMessages(a, userPrompt, history)
    tools := bridgeTools(a.Bridge)

    for round from 0 to maxRounds
        client := buildLLMClient(a, messages, tools)
        events, collect := chat.SendStream(client)

        for evt in events
            if a.OnText isnt empty
                if evt is llm.Delta as d
                    a.OnText(d.Body)

        comp, sErr := collect()
        if sErr isnt empty
            return empty, error "LLM request failed (round {round}): {sErr}"

        content := chat.GetText(comp)

        if not chat.HasToolCalls(comp)
            return reference of RunResult{Content: content, Messages: messages, Rounds: round + 1}, empty

        messages = handleToolCalls(ctx, a, messages, comp, content)

    return empty, error "agent hit max rounds ({maxRounds}) without completing"

func initMessages(a: reference Agent, userPrompt: string, history: list of chat.Message) list of chat.Message
    messages := append(empty list of chat.Message, many history)

    if len(messages) equals 0
        sys := a.SystemPrompt
        if sys equals ""
            sys = defaultSystemPrompt
        messages = append(messages, chat.Message{Role: "system", Content: sys})

    return append(messages, chat.Message{Role: "user", Content: userPrompt})

func buildLLMClient(a: reference Agent, messages: list of chat.Message, tools: list of chat.Tool) chat.Client
    client := chat.New("")
        |> chat.Model(a.Config.Model)
        |> chat.BaseURL(a.Config.WebUIURL)
        |> chat.Path("/api/chat/completions")
        |> chat.APIKey(a.Config.WebUIAPIKey)
        |> chat.Messages(messages)

    for t in tools
        client = chat.AddTool(client, t.Function.Name, t.Function.Description, t.Function.Parameters)

    if len(tools) > 0
        client = chat.ToolChoiceAuto(client)

    return client

func handleToolCalls(ctx: context.Context, a: reference Agent, messages: list of chat.Message, comp: chat.Completion, content: string) list of chat.Message
    toolCalls := chat.GetToolCalls(comp)

    messages = append(messages, chat.Message{Role: "assistant", Content: content, ToolCalls: toolCalls})

    for _, tc in toolCalls
        if a.OnToolCall isnt empty
            a.OnToolCall(tc.Function.Name, tc.Function.Arguments)

        toolResult := callBridgeTool(ctx, a.Bridge, tc.Function.Name, tc.Function.Arguments) onerr
            toolResult = "ERROR: {error}"

        if a.OnToolResult isnt empty
            a.OnToolResult(tc.Function.Name, strpkg.Truncate(toolResult, 500))

        messages = append(messages, chat.Message{Role: "tool", Content: toolResult, ToolCallID: tc.ID})

    return messages
